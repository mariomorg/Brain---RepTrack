{
  "manifest_version": 3,
  "name": "BrainRepTrack Inbox",
  "version": "2.0.0",
  "description": "Captura ideas, enlaces, texto seleccionado o la pestaña actual y envíalos directo al Inbox desde cualquier página.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "BrainRepTrack Inbox (Ctrl+Shift+I)"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://localhost:8080/*"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+I",
        "mac": "Command+Shift+I"
      },
      "description": "Abrir Inbox rápido"
    },
    "capture-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Capturar página actual al Inbox"
    }
  }
}